{
  "openapi": "3.0.0",
  "info": {
    "title": "API Calculadora de Missões",
    "version": "1.0.0",
    "description": "Documentação das rotas de autenticação da API Calculadora de Missões - Akatsuki"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Servidor local de desenvolvimento"
    }
  ],
  "paths": {
    "/api/auth/register": {
      "post": {
        "summary": "Registra um novo usuário",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Usuário criado com sucesso" },
          "400": { "description": "Usuário já existe" },
          "500": { "description": "Erro interno" }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Realiza login do usuário",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string" },
                  "password": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login bem-sucedido" },
          "401": { "description": "Credenciais inválidas" },
          "500": { "description": "Erro interno" }
        }
      }
    },
    "/api/auth/refresh": {
      "post": {
        "summary": "Gera novo access token usando refresh token",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["refreshToken"],
                "properties": {
                  "refreshToken": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Novo access token gerado" },
          "401": { "description": "Refresh token inválido" }
        }
      }
    },
    "/api/auth/perfil": {
      "get": {
        "summary": "Retorna dados do perfil do usuário autenticado",
        "tags": ["Auth"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "responses": {
          "200": { "description": "Dados do perfil retornados com sucesso" },
          "401": { "description": "Token inválido ou ausente" },
          "404": { "description": "Usuário não encontrado" },
          "500": { "description": "Erro interno" }
        }
      }
    },
    "/categories": {
    "get": {
      "summary": "Lista todas as categorias",
      "tags": ["Category"],
      "responses": {
        "200": {
          "description": "Lista de categorias retornada com sucesso"
        },
        "500": {
          "description": "Erro ao buscar categorias"
        }
      }
    },
    "post": {
      "summary": "Cria uma nova categoria",
      "tags": ["Category"],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "required": ["name"],
              "properties": {
                "name": { "type": "string" },
                "costs_id": { "type": "string" },
                "types_id": { "type": "string" },
                "missions_id": { "type": "string" }
              }
            }
          }
        }
      },
      "responses": {
        "201": { "description": "Categoria criada com sucesso" },
        "400": { "description": "Dados inválidos ou incompletos" },
        "409": { "description": "Categoria com costs_id já existe" },
        "500": { "description": "Erro ao criar categoria" }
      }
    }
  },
  "/categories/{id}": {
    "get": {
      "summary": "Busca uma categoria pelo ID",
      "tags": ["Category"],
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": { "type": "string" }
        }
      ],
      "responses": {
        "200": { "description": "Categoria encontrada com sucesso" },
        "400": { "description": "ID inválido" },
        "404": { "description": "Categoria não encontrada" },
        "500": { "description": "Erro ao buscar categoria" }
      }
    },
    "put": {
      "summary": "Atualiza uma categoria existente",
      "tags": ["Category"],
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": { "type": "string" }
        }
      ],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "costs_id": { "type": "string" },
                "types_id": { "type": "string" },
                "missions_id": { "type": "string" }
              }
            }
          }
        }
      },
      "responses": {
        "200": { "description": "Categoria atualizada com sucesso" },
        "400": { "description": "Dados inválidos ou incompletos" },
        "404": { "description": "Categoria não encontrada" },
        "409": { "description": "Conflito de dados únicos" },
        "500": { "description": "Erro ao atualizar categoria" }
      }
    },
    "delete": {
      "summary": "Remove uma categoria pelo ID",
      "tags": ["Category"],
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": { "type": "string" }
        }
      ],
      "responses": {
        "200": { "description": "Categoria removida com sucesso" },
        "400": { "description": "ID inválido" },
        "404": { "description": "Categoria não encontrada" },
        "409": { "description": "Categoria possui relacionamentos ativos" },
        "500": { "description": "Erro ao remover categoria" }
      }
    }
  },
  "/missions": {
    "get": {
      "summary": "Lista todas as missões",
      "tags": ["Mission"],
      "responses": {
        "200": { "description": "Lista de missões retornada com sucesso" },
        "500": { "description": "Erro ao buscar missões" }
      }
    },
    "post": {
      "summary": "Cria uma nova missão",
      "tags": ["Mission"],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "required": ["name", "user_id"],
              "properties": {
                "name": { "type": "string" },
                "number_participants": { "type": "integer" },
                "description": { "type": "string" },
                "user_id": { "type": "integer" }
              }
            }
          }
        }
      },
      "responses": {
        "200": { "description": "Missão criada com sucesso" },
        "400": { "description": "Dados incompletos" },
        "500": { "description": "Erro ao criar missão" }
      }
    }
  },
  "/missions/users/{user_id}": {
    "get": {
      "summary": "Busca missões por ID de usuário",
      "tags": ["Mission"],
      "parameters": [
        {
          "name": "user_id",
          "in": "path",
          "required": true,
          "schema": { "type": "integer" }
        }
      ],
      "responses": {
        "200": { "description": "Missões do usuário retornadas com sucesso" },
        "404": { "description": "Missão não encontrada" },
        "500": { "description": "Erro ao buscar missão" }
      }
    }
  },
  "/missions/{id}": {
    "get": {
      "summary": "Busca missão por ID",
      "tags": ["Mission"],
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": { "type": "integer" }
        }
      ],
      "responses": {
        "200": { "description": "Missão encontrada com sucesso" },
        "400": { "description": "ID inválido" },
        "404": { "description": "Missão não encontrada" },
        "500": { "description": "Erro ao buscar missão" }
      }
    },
    "put": {
      "summary": "Atualiza missão existente",
      "tags": ["Mission"],
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": { "type": "integer" }
        }
      ],
      "requestBody": {
        "required": true,
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "number_participants": { "type": "integer" },
                "description": { "type": "string" }
              }
            }
          }
        }
      },
      "responses": {
        "200": { "description": "Missão atualizada com sucesso" },
        "400": { "description": "Dados inválidos ou incompletos" },
        "500": { "description": "Erro ao atualizar missão" }
      }
    },
    "delete": {
      "summary": "Remove missão por ID",
      "tags": ["Mission"],
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": { "type": "integer" }
        }
      ],
      "responses": {
        "204": { "description": "Missão removida com sucesso" },
        "400": { "description": "ID inválido" },
        "500": { "description": "Erro ao remover missão" }
      }
    }
  }

  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}