generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Categories {
  id         Int       @id @default(autoincrement()) @db.SmallInt
  name       String?   @db.VarChar
  created_at DateTime  @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
  type_id    Int?      @db.SmallInt
  mission_id Int?      @db.SmallInt
  Missions   Missions? @relation(fields: [mission_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Types      Types?    @relation(fields: [type_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Costs      Costs[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Costs {
  id                 Int         @id @default(autoincrement()) @db.SmallInt
  description        String?     @db.VarChar
  initial_quantity   Int?        @db.SmallInt
  initial_unit_value Int?        @db.SmallInt
  final_quantity     Int?        @db.SmallInt
  final_unit_value   Int?        @db.SmallInt
  observation        String?     @db.VarChar
  category_id        Int?        @db.SmallInt
  selected           Boolean?
  Categories         Categories? @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model DefaultTaxes {
  id          Int       @id(map: "tax_pkey") @default(autoincrement()) @db.SmallInt
  name        String?   @db.VarChar
  description String?   @db.VarChar
  value       Float?
  updated_at  DateTime? @default(now()) @db.Timestamp(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Levels {
  id          Int     @id @default(autoincrement()) @db.SmallInt
  description String? @db.VarChar
  Users       Users[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Missions {
  id                               Int          @id(map: "Mission_pkey") @default(autoincrement()) @db.SmallInt
  name                             String?      @db.VarChar
  number_participants              Int?         @db.SmallInt
  description                      String?      @db.VarChar
  created_at                       DateTime     @default(now()) @db.Timestamp(6)
  updated_at                       DateTime?    @default(now()) @db.Timestamp(6)
  user_id                          Int?         @db.SmallInt
  number_consolidated_participants Int?         @db.SmallInt
  Categories                       Categories[]
  Users                            Users?       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  Taxes                            Taxes[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Taxes {
  id          Int       @id(map: "Sub_taxes_pkey") @default(autoincrement()) @db.SmallInt
  name        String?   @db.VarChar
  description String?   @db.VarChar
  value       Float?
  mission_id  Int?      @db.SmallInt
  updated_at  DateTime? @default(now()) @db.Timestamp(6)
  Missions    Missions? @relation(fields: [mission_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Types {
  id         Int          @id(map: "Typess_pkey") @default(autoincrement()) @db.SmallInt
  name       String?      @db.VarChar
  flow       Type_flow?
  Categories Categories[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Users {
  id         Int        @id(map: "User_pkey") @default(autoincrement()) @db.SmallInt
  email      String     @unique(map: "Users_username_key") @db.VarChar
  password   String     @db.VarChar
  created_at DateTime   @default(now()) @db.Timestamp(6)
  updated_at DateTime?  @default(now()) @db.Timestamp(6)
  level_id   Int?       @db.SmallInt
  name       String?    @db.VarChar
  Missions   Missions[]
  Levels     Levels?    @relation(fields: [level_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

enum Type_flow {
  fixed_costs    @map("fixed costs")
  variable_costs @map("variable costs")
}
